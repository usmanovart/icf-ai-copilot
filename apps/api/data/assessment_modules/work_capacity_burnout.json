      "labels": ["Never", "Rarely", "Sometimes", "Often", "Always"],
      "reverse_scored": false
    },
    {
      "key": "bu_ex2",
      "dimension": "exhaustion",
      "text": "I feel used up at the end of a workday.",
      "type": "likert5",
      "labels": ["Never", "Rarely", "Sometimes", "Often", "Always"],
      "reverse_scored": false
