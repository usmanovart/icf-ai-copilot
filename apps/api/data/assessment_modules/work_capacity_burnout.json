{
  "module_id": "work_capacity_burnout",
  "domain": "work_capacity",
  "title": "Work Capacity & Burnout Risk",
  "description": "Assesses your current energy levels and burnout risk indicators across three dimensions from Maslach burnout research: exhaustion, depersonalisation, and personal efficacy.",
  "disclaimer": "This is a non-diagnostic self-reflection tool. It does not constitute a clinical burnout assessment. If you are experiencing significant work-related distress, please speak to a healthcare professional or HR specialist.",
  "estimated_minutes": 4,
  "scoring": "mean_per_dimension",
  "dimensions": ["exhaustion", "depersonalisation", "efficacy", "energy", "focus"],
  "risk_thresholds": {
    "exhaustion": {"low": [0, 1.8], "moderate": [1.9, 3.2], "high": [3.3, 5.0]},
    "depersonalisation": {"low": [0, 1.5], "moderate": [1.6, 2.8], "high": [2.9, 5.0]},
    "efficacy": {"low": [3.5, 5.0], "moderate": [2.5, 3.4], "high": [0, 2.4]}
  },
  "questions": [
