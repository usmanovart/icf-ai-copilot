# ══════════════════════════════════════════════════════════════════════════════
# ICF AI Copilot — Environment Variables
#
# Copy this file to:
#   apps/api/.env     (for the FastAPI backend)
#   apps/web/.env.local  (for the Next.js frontend)
#
# NEVER commit real secrets. All values here are placeholders.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# ─── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
# Local dev: matches docker-compose.yml
DATABASE_URL=postgresql+asyncpg://icf:icf@localhost:5432/icf
# Production: use your Railway / Neon PostgreSQL URL
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

REDIS_URL=redis://localhost:6379/0
# Production: use Upstash Redis URL
# REDIS_URL=rediss://default:password@host:port

# ─── Clerk Authentication ─────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
CLERK_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE
# Webhook signing secret — from Clerk Dashboard → Webhooks → your endpoint
CLERK_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE
# JWKS URL — do not change unless self-hosting Clerk
CLERK_JWKS_URL=https://api.clerk.dev/v1/jwks

# ─── Next.js Public Variables (prefix NEXT_PUBLIC_ for client exposure) ───────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── IBM watsonx.ai ───────────────────────────────────────────────────────────
# Get API key from: https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your_ibm_cloud_api_key_here
# Get Project ID from: https://dataplatform.cloud.ibm.com → your project → Manage → General
WATSONX_PROJECT_ID=your_watsonx_project_id_here
# watsonx.ai endpoint — us-south is default; change for your region
WATSONX_URL=https://us-south.ml.cloud.ibm.com
# LLM model to use for generation
WATSONX_LLM_MODEL_ID=ibm/granite-13b-chat-v2
# Embedding model for pgvector
WATSONX_EMBEDDING_MODEL_ID=ibm/slate-125m-english-rtrvr

# ─── Watson Discovery (RAG knowledge corpus) ──────────────────────────────────
# Get from: IBM Cloud → Watson Discovery service → Service credentials
WATSON_DISCOVERY_API_KEY=your_watson_discovery_api_key_here
WATSON_DISCOVERY_URL=https://api.us-south.discovery.watson.cloud.ibm.com
# Project ID from Watson Discovery → your project → API information
WATSON_DISCOVERY_PROJECT_ID=your_discovery_project_id_here

# ─── watsonx.governance (OpenScale / AI Fairness 360) ────────────────────────
WATSONX_GOVERNANCE_URL=https://aiopenscale.cloud.ibm.com
WATSONX_GOVERNANCE_API_KEY=your_governance_api_key_here

# ─── Safety & Compliance ──────────────────────────────────────────────────────
# Minimum number of users required before showing aggregated org/coach insights
# (prevents re-identification — do not lower below 5)
MIN_ANONYMIZATION_COHORT=5
# Active version of the consent document
CONSENT_DOCUMENT_VERSION=1.0
